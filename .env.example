# ── Frontend (Vite) ──────────────────────────────────────────
# Google Sheet ID (from the URL: .../spreadsheets/d/<SHEET_ID>/...)
VITE_GOOGLE_SHEET_ID=

# Service account email (from your downloaded credentials JSON)
VITE_GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Service account private key — keep \n escaped as-is
VITE_GOOGLE_PRIVATE_KEY=

# Gemini API Key (from Google AI Studio: https://aistudio.google.com/app/apikey)
# Option A: single key
VITE_GEMINI_API_KEY=
# Option B: multiple keys for quota fallback — tries each in order when one hits its limit
# VITE_GEMINI_API_KEY_2=
# VITE_GEMINI_API_KEY_3=
# Option C: comma-separated list (overrides A+B if set)
# VITE_GEMINI_API_KEYS=key1,key2,key3
# Optional: override the model used for Smart Import (default: gemini-2.0-flash)
# VITE_GEMINI_MODEL=gemini-2.0-flash

# ── Python Bot ───────────────────────────────────────────────
# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID — get from @userinfobot
TELEGRAM_CHAT_ID=

# Same Sheet ID as above
GOOGLE_SHEET_ID=

# Full contents of your service account JSON file (paste as one line)
GOOGLE_CREDENTIALS_JSON=
