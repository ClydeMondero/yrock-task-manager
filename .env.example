# ── Frontend (Vite) ──────────────────────────────────────────
# Google Sheet ID (from the URL: .../spreadsheets/d/<SHEET_ID>/...)
VITE_GOOGLE_SHEET_ID=

# Service account email (from your downloaded credentials JSON)
VITE_GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Service account private key — keep \n escaped as-is
VITE_GOOGLE_PRIVATE_KEY=

# Gemini API Key (from Google AI Studio)
VITE_GEMINI_API_KEY=

# ── Python Bot ───────────────────────────────────────────────
# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your Telegram chat ID — get from @userinfobot
TELEGRAM_CHAT_ID=

# Same Sheet ID as above
GOOGLE_SHEET_ID=

# Full contents of your service account JSON file (paste as one line)
GOOGLE_CREDENTIALS_JSON=
